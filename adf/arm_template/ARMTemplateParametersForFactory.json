{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "factoryName": { "value": "adf-ecommerce-analytics" },
    "adlsAccountUrl": { "value": "https://<your_adls_account>.dfs.core.windows.net/" },
    "databricksDomain": { "value": "https://<your-workspace>.azuredatabricks.net" },
    "databricksWorkspaceResourceId": { "value": "/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.Databricks/workspaces/<workspace>" },
    "keyVaultBaseUrl": { "value": "https://<your-keyvault>.vault.azure.net/" }
  }
}
